<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvTituloVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mini Vídeos Temáticos"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:background="#0D47A1"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_margin="-16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal"
        android:background="@drawable/fundo_card_branco"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Digite o tipo de vídeo que quer assistir"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etBuscaVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="tecnologia"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"
            android:inputType="text" />

        <Button
            android:id="@+id/btnBuscarVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buscar vídeo"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <VideoView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnPlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Play"
                android:layout_marginEnd="16dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pause"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vídeo selecionado: "
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvVideoSelecionado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnTela2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sobre o desenvolvedor"
        android:background="@drawable/fundo_botao_borda" android:textColor="#1565C0"
        android:layout_marginBottom="8dp" />

</LinearLayout>