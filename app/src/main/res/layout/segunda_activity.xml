<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0D47A1"
        android:padding="16dp"
        android:layout_margin="-16dp"> <ImageButton
        android:id="@+id/btnVoltarSuperior"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:tint="#FFFFFF"
        android:contentDescription="Voltar" />

        <TextView
            android:id="@+id/tvToolbarTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sobre"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal"
        android:background="@drawable/fundo_card_branco"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/imgPerfilSobre"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:scaleType="centerCrop"
            android:background="@drawable/background_circulo"
            android:clipToOutline="true" />

        <TextView
            android:id="@+id/tvTituloSobre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adrien Bezerra"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSubtituloSobre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Desenvolvedor Mobile"
            android:textColor="#1565C0"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvTextoSobre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estudante de Análise e Desenvolvimento de Sistemas. Apaixonado por tecnologia, desenvolvimento Android nativo com Kotlin e criação de soluções mobile inteligentes."
            android:textColor="#555555"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnVoltarInferior"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Voltar"
        android:background="@drawable/fundo_botao_borda"
        android:textColor="#1565C0"
        android:layout_marginBottom="8dp" />

</LinearLayout>
</ScrollView>